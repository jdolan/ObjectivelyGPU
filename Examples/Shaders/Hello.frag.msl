#include <metal_stdlib>
#include <simd/simd.h>

using namespace metal;

struct fs_main_out
{
    float4 _entryPointOutput [[color(0)]];
};

struct fs_main_in
{
    float4 input_color [[user(locn0)]];
};

fragment fs_main_out fs_main(fs_main_in in [[stage_in]])
{
    fs_main_out out = {};
    out._entryPointOutput = in.input_color;
    return out;
}

